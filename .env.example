# =====================================================
# Smart Note - 环境变量示例
# 复制为 .env.local 后填入真实值
# =====================================================

# ---------- Supabase ----------
# 在 https://supabase.com/dashboard 创建项目后，从 Project Settings > API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 仅服务端使用，绝不暴露到客户端
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- Prisma (Supabase Postgres) ----------
# 注意：Pooler 强制要求 SSL，URL 末尾必须带 sslmode=require
# Pooler 连接（应用运行时用，6543 端口 - Transaction mode）
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# 直连（用于 prisma migrate / db push，5432 端口 - Session mode）
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# ---------- 站点绝对地址（推送通知里的链接；本地与生产分别配置）----------
NEXT_PUBLIC_APP_URL=http://localhost:3005

# ---------- Web Push（M4）----------
# 生成：`npx web-push generate-vapid-keys`
# 公钥需同时给浏览器订阅用（NEXT_PUBLIC_）与服务端发送用（可与上一致）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Vercel Cron 调用 /api/cron/remind 时校验：Authorization: Bearer <CRON_SECRET>
# 本地调试：curl -H "Authorization: Bearer xxx" http://localhost:3005/api/cron/remind
CRON_SECRET=

# ---------- FCM（可选，后续 Android 原生通道）----------
FCM_SERVER_KEY=
